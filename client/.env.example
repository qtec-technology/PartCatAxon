# Base path for the frontend app
VITE_APP_BASE_PATH=/

# Local API proxy target (required in dev to call /api/* from Vite dev server)
VITE_API_PROXY_TARGET=http://localhost:3001

# Frontend UX flags. SERVER_READ_ONLY is the backend enforcement switch.
VITE_READ_ONLY_MODE=false
VITE_ENABLE_ADD_ITEM=true
