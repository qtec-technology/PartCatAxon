{
    "name": "partcatalog-api",
    "version": "1.0.0",
    "description": "PartCatalog Backend API Server",
    "type": "module",
    "imports": {
        "#src/*": {
            "development": "./src/*",
            "default": "./dist/*"
        }
    },
    "scripts": {
        "dev": "tsx watch --conditions=development src/index.ts",
        "check:imports": "node scripts/check-import-alias.mjs",
        "check:schema": "tsx --conditions=development scripts/check-item-schema.ts",
        "prebuild": "npm run check:imports",
        "build": "tsc",
        "prestart": "npm run check:imports",
        "start": "node dist/index.js",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@partcatalog/shared-types": "file:../packages/shared-types",
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "express-rate-limit": "^8.4.0",
        "helmet": "^8.0.0",
        "morgan": "^1.10.0",
        "msnodesqlv8": "^5.1.5",
        "mssql": "^11.0.1",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/morgan": "^1.9.10",
        "@types/mssql": "^9.1.9",
        "@types/node": "^22.13.4",
        "tsx": "^4.19.3",
        "typescript": "^5.7.3",
        "vitest": "^4.0.18"
    },
    "overrides": {
        "uuid": "14.0.0"
    }
}
