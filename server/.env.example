# PartCatalog API Configuration
# Copy this file to .env and fill in actual values

NODE_ENV=development
PORT=3001

# SQL Server Connection
DB_HOST=<SQL_SERVER_HOST>
DB_PORT=1433
DB_NAME_QTEC=PART_CATALOG_AIX
DB_NAME_SAP=SBOQTEC
DB_USER=<DB_USERNAME>
DB_PASSWORD=<DB_PASSWORD>

# AXON handoff read-only views.
# Leave blank until Pi-Jo confirms the final comparison view names.
# When blank, GET /api/axon-handoff/comparisons/:chainId returns 501 instead of guessing.
# Proposed AXON-side contract names are documented in:
# server/sql/20260519_axon_handoff_view_contract.sql
DB_VIEW_AXON_FINAL_COMPARISON_HEADER=
DB_VIEW_AXON_FINAL_COMPARISON_LINES=

# File storage paths (UNC paths to network shares)
ITEM_IMAGE_DIR=\\<FILE_SERVER>\AttachmentItemImage
USER_PICTURE_DIR=\\<FILE_SERVER>\<SHARE>\user_picture
ATTACHMENT_DIR=\\<FILE_SERVER>\Attachment

# Term page reference files (UNC paths)
REF_FILE_INCOTERMS_2020_PDF=\\<FILE_SERVER>\<SHARE>\incoterms2020_summary.pdf
REF_FILE_INCOTERMS_CHART=\\<FILE_SERVER>\<SHARE>\Incoterms2020.jpg
REF_FILE_UOM_MANUAL=\\<FILE_SERVER>\<SHARE>\UOM.ppsx
REF_FILE_STANDARD_CUSTOM_COST_TABLE=\\<FILE_SERVER>\<SHARE>\STD Customs Cost.xlsx
REF_FILE_DOMESTIC_AGENT_PRICE_TABLE=\\<FILE_SERVER>\<SHARE>\DomesticAgent.xlsx

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3010

# Role Configuration (comma-separated usernames, case-insensitive)
ROLE_MANAGERS=
ROLE_SUPERVISORS=

# Dev-mode user display (used only when NODE_ENV is not "production")
DEV_DISPLAY_NAME=Your Name
DEV_EMAIL=you@company.com
