# PartCatalog API Configuration
# NODE_ENV behavior in this app:
# - production: use IIS/Windows-auth headers, hide error details, use morgan combined logs.
# - non-production (development/staging/etc): use local/dev auth flow, include error stack/details, use morgan dev logs.
NODE_ENV=development
PORT=3001

# SQL Server Connection (required)
DB_HOST=<SQL_SERVER_HOST>
DB_PORT=1433
DB_NAME_QTEC=<QTEC_DATABASE_NAME>
DB_NAME_SAP=<SAP_DATABASE_NAME>
DB_USER=<SQL_USERNAME>
DB_PASSWORD=<ASK_ADMIN_FOR_PASSWORD>

# File storage
ITEM_IMAGE_DIR=\\<FILE_SERVER>\AttachmentItemImage
USER_PICTURE_DIR=\\<FILE_SERVER>\_PartCat_Resource\user_picture

# CORS
# Prefer CORS_ALLOWED_ORIGINS (comma-separated). CORS_ORIGIN is still supported as legacy fallback.
CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
# CORS_ORIGIN=https://app.example.com

# Role Configuration (comma-separated usernames, case-insensitive)
ROLE_MANAGERS=
ROLE_SUPERVISORS=

# Dev-mode user display (simulates Windows Auth response)
# Used only when NODE_ENV is not "production".
DEV_DISPLAY_NAME=
DEV_EMAIL=