# ── Next.js Shell Environment (copy to .env.local and fill in values) ────────
EXPRESS_API_URL=http://localhost:3001
EXPRESS_CSRF_ORIGIN=http://localhost:3010

# Show full formula / calculation breakdown tables in Bulk Cost Result Review.
# Set to "true" for internal dev/review. Remove or set to "false" for production.
NEXT_PUBLIC_SHOW_FORMULA=false
